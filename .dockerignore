CMakeCache.txt
cmake_install.cmake
cmake-build-*/
cmake-build/
.cmake-*/
compile_commands.json
build/*
!build/*.bat

# ═══════════════════════════════════════════════════════════════
#  Python / Cache
# ═══════════════════════════════════════════════════════════════
__pycache__/
*.pyc
.cache/

