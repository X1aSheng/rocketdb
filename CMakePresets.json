{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with all tests and examples",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_EXAMPLES": "ON",
                "BUILD_PERF": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "description": "Release build with optimizations",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_EXAMPLES": "ON",
                "BUILD_PERF": "ON"
            }
        },
        {
            "name": "debug-win",
            "displayName": "Debug (Windows Clang)",
            "description": "Debug build with Clang on Windows.  clang must be in PATH or override CMAKE_C_COMPILER with the full path.",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang"
            }
        },
        {
            "name": "minimal",
            "displayName": "Minimal",
            "description": "Minimal build with no tests or examples",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/cmake-build-minimal",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF",
                "BUILD_EXAMPLES": "OFF",
                "BUILD_PERF": "OFF"
            }
        },
        {
            "name": "sanitize",
            "displayName": "Sanitizer",
            "description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_SANITIZER": "ON",
                "ENABLE_STRICT_WARNINGS": "ON"
            }
        },
        {
            "name": "ci-ubuntu",
            "displayName": "CI Ubuntu",
            "description": "CI build for Ubuntu (used by GitHub Actions)",
            "inherits": "debug",
            "cacheVariables": {
                "ENABLE_STRICT_WARNINGS": "ON"
            }
        },
        {
            "name": "ci-win",
            "displayName": "CI Windows",
            "description": "CI build for Windows with Clang (used by GitHub Actions)",
            "inherits": "debug-win",
            "cacheVariables": {
                "ENABLE_STRICT_WARNINGS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "configuration": "Debug"
        },
        {
            "name": "release",
            "configurePreset": "release",
            "configuration": "Release"
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "configurePreset": "debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "release",
            "configurePreset": "release",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
